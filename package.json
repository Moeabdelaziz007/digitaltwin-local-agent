{
  "name": "digital-mini-twin",
  "version": "1.0.0",
  "description": "Architecting a Private, Voice-First AI Digital Twin. Built with Next.js 15, Go sidecars, and local LLMs.",
  "author": "Mohamed Hossameldin Abdelaziz (@Moeabdelaziz007)",
  "license": "MIT",
  "scripts": {
    "dev": "next dev --turbopack",
    "typecheck": "tsc --noEmit",
    "lint": "next lint",
    "generate:types": "npx tsx scripts/generate-contracts.ts",
    "prebuild": "npm run generate:types",
    "build": "node scripts/check-env.mjs && npm run generate:types && next build",
    "start": "next start",
    "verify": "chmod +x scripts/quality-gate.sh && ./scripts/quality-gate.sh",
    "check:env": "node scripts/check-env.mjs",
    "check:smoke": "node scripts/check-smoke.mjs",
    "scan-bugs": "grep -rinE 'console\\.log|TODO|FIXME|localhost|sk_test|pk_test|body\\.userId' src/ || echo 'Zero critical debugging artifacts found!'",
    "test:cron:decay": "curl -H 'Authorization: Bearer test' http://localhost:3000/api/cron/decay",
    "test:cron:snapshot": "curl -H 'Authorization: Bearer test' http://localhost:3000/api/cron/snapshot",
    "check:memory-dataset": "node scripts/check-memory-dataset-version.js",
    "test": "vitest run"
  },
  "dependencies": {
    "@ai-sdk/groq": "^3.0.35",
    "@browserbasehq/sdk": "^2.10.0",
    "@clerk/nextjs": "^5.7.0",
    "@clerk/themes": "^2.1.0",
    "@livekit/components-react": "^2.5.0",
    "@livekit/components-styles": "^1.0.12",
    "@opentelemetry/api": "^1.9.0",
    "@opentelemetry/api-logs": "^0.55.0",
    "@opentelemetry/core": "^1.30.0",
    "@opentelemetry/exporter-jaeger": "^2.7.0",
    "@opentelemetry/resources": "^1.30.0",
    "@opentelemetry/sdk-logs": "^0.55.0",
    "@opentelemetry/sdk-node": "^0.55.0",
    "@opentelemetry/sdk-trace-base": "^1.30.0",
    "@opentelemetry/semantic-conventions": "^1.30.0",
    "@vercel/otel": "^2.1.2",
    "@xyflow/react": "^12.10.2",
    "ai": "^4.3.0",
    "braintrust": "^3.9.0",
    "clsx": "^2.1.1",
    "framer-motion": "^12.38.0",
    "groq-sdk": "^0.8.0",
    "livekit-client": "^2.5.0",
    "livekit-server-sdk": "^2.15.1",
    "lucide-react": "^0.460.0",
    "next": "^15.2.4",
    "playwright-core": "^1.59.1",
    "pocketbase": "^0.26.8",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "svix": "^1.40.0",
    "tailwind-merge": "^2.5.5",
    "uuid": "^11.0.3",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.1.0",
    "@tailwindcss/postcss": "4.0.0-beta.8",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "^15.2.4",
    "tailwindcss": "4.0.0-beta.8",
    "typescript": "^5"
  },
  "engines": {
    "node": "22.x"
  },
  "packageManager": "pnpm@10.23.0+sha512.21c4e5698002ade97e4efe8b8b4a89a8de3c85a37919f957e7a0f30f38fbc5bbdd05980ffe29179b2fb6e6e691242e098d945d1601772cad0fef5fb6411e2a4b",
  "pnpm": {
    "overrides": {
      "@opentelemetry/api": "1.9.0",
      "@opentelemetry/core": "1.30.0",
      "@opentelemetry/sdk-trace-base": "1.30.0",
      "@opentelemetry/resources": "1.30.0",
      "@opentelemetry/semantic-conventions": "1.30.0"
    }
  }
}
