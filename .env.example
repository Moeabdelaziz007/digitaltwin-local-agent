# --- Core auth (Clerk) ---
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_xxx # Public Clerk key for frontend auth UI
CLERK_SECRET_KEY=sk_test_xxx # Secret Clerk backend key for server auth
CLERK_WEBHOOK_SECRET=whsec_xxx # Secret used to verify Clerk webhook signatures

# --- Data layer ---
POCKETBASE_URL=http://localhost:8090 # PocketBase HTTP URL used by server routes
NEXT_PUBLIC_POCKETBASE_URL=http://localhost:8090 # Optional public PocketBase URL for client utilities

# --- Twin sidecar / reflection ---
SIDECAR_URL=http://localhost:8081 # Reflection sidecar base URL (used by /api/conversation)
SIDECAR_SHARED_SECRET=replace_me # Shared secret between Next.js and sidecar

# --- Cron security ---
CRON_SECRET=replace_me # Bearer secret for /api/cron/* endpoints

# --- Local LLM (optional, with defaults) ---
OLLAMA_URL=http://localhost:11434 # Optional Ollama endpoint
OLLAMA_MODEL=gemma4 # Optional default model name

# --- Voice bridge (optional) ---
LIVEKIT_URL=wss://your-livekit-host # LiveKit websocket URL
LIVEKIT_API_KEY=your_livekit_api_key # LiveKit API key for token minting
LIVEKIT_API_SECRET=your_livekit_api_secret # LiveKit API secret for token minting
NEXT_PUBLIC_LIVEKIT_URL=wss://your-livekit-host # Optional client fallback URL

# --- Observability (optional) ---
NEXT_PUBLIC_SENTRY_DSN= # Optional Sentry DSN for browser telemetry
