# ═══════════════════════════════════════════════════════
# MAS-ZERO Digital Twin - Environment Variables Template
# Copy this file to .env.local and fill in your values
# ═══════════════════════════════════════════════════════

# ── Braintrust (Observability & Tracing) ──
BRAINTRUST_API_KEY="bt-st-YOUR_API_KEY_HERE"
BRAINTRUST_PROJECT_ID="your-project-id-here"

# ── Browserbase (Cloud Browser Automation) ──
BROWSERBASE_API_KEY=bb_live_YOUR_API_KEY_HERE
BROWSERBASE_PROJECT_ID=your-project-id-here

# ── Mixedbread AI (Embeddings & Vector Store) ──
MXBAI_API_KEY="mxb_YOUR_API_KEY_HERE"
MXBAI_STORE_ID="your-store-id-here"

# ── Meticulous (Session Recording & Auto-Testing) ──
METICULOUS_RECORDING_TOKEN="your-recording-token-here"

# ── Groq (Fast AI Inference - Free Models) ──
GROQ_API_KEY="gsk_your-api-key-here"

# ── Sentry (Error Monitoring) ──
SENTRY_AUTH_TOKEN=your-sentry-auth-token
NEXT_PUBLIC_SENTRY_DSN=https://your-dsn@sentry.io/project-id
SENTRY_DSN=https://your-dsn@sentry.io/project-id

# ── LiveKit Voice Infrastructure ──
LIVEKIT_URL=wss://your-project.livekit.cloud
LIVEKIT_API_KEY=your-api-key
LIVEKIT_API_SECRET=your-api-secret

# ── PocketBase (Local Database) ──
NEXT_PUBLIC_POCKETBASE_URL=http://localhost:8090
POCKETBASE_URL=http://localhost:8090

# ── Ollama (Local LLM) ──
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=gemma

# ── Go Sidecar ──
SIDECAR_URL=http://localhost:4242

# ── PocketBase Admin ──
PB_ADMIN_EMAIL=admin@twin.local
PB_ADMIN_PASSWORD=changeme_on_first_run

# ── Vercel Cron Security ──
CRON_SECRET=generate-with-openssl-rand-hex-32
SIDECAR_SHARED_SECRET=dev_secret_only

# ── Clerk Authentication ──
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_your-key
CLERK_SECRET_KEY=sk_test_your-key
NEXT_PUBLIC_CLERK_FRONTEND_API=https://your-app.clerk.accounts.dev
CLERK_JWKS_URL=https://your-app.clerk.accounts.dev/.well-known/jwks.json
CLERK_WEBHOOK_SECRET=whsec_your-webhook-secret
